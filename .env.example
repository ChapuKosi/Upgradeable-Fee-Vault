# Deployment Configuration
PRIVATE_KEY=your_private_key_here
VAULT_OWNER=your_owner_address_here

# RPC URL (from Alchemy dashboard - already includes the API key)
# Example: https://eth-sepolia.g.alchemy.com/v2/AbCdEfGhIjKlMnOpQrStUvWx
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Etherscan API Key (for contract verification - get from etherscan.io)
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# V2 Upgrade Configuration (optional - fill after V1 deployment)
VAULT_PROXY=deployed_proxy_address_here
MAX_WITHDRAW_PER_TX=0
WITHDRAWAL_DELAY=86400
